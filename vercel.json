{
  "routes": [
    {
      "src": "/calendar",
      "has": [
        { "type": "header", "key": "user-agent", "value": ".*(bot|crawler|spider|facebookexternalhit).*" }
      ],
      "dest": "/calendar-og.html",
      "status": 200
    },
    {
      "src": "/brandos",
      "has": [
        { "type": "header", "key": "user-agent", "value": ".*(bot|crawler|spider|facebookexternalhit).*" }
      ],
      "dest": "/brandos-og.html",
      "status": 200
    },
    {
      "src": "/pulsenote",
      "has": [
        { "type": "header", "key": "user-agent", "value": ".*(bot|crawler|spider|facebookexternalhit).*" }
      ],
      "dest": "/pulsenote-og.html",
      "status": 200
    },
    { "src": "/book-demo", "status": 301, "headers": { "Location": "/pulsenote" } },
    { "src": "/brand-analyzer", "status": 301, "headers": { "Location": "/brandos" } },
    { "src": "/shootos", "status": 301, "headers": { "Location": "/autopilot" } },
    {
      "src": "/briefings",
      "has": [
        { "type": "header", "key": "user-agent", "value": ".*(bot|crawler|spider|facebookexternalhit).*" }
      ],
      "dest": "/briefings-og.html",
      "status": 200
    },
    {
      "src": "/who-we-are",
      "has": [
        { "type": "header", "key": "user-agent", "value": ".*(bot|crawler|spider|facebookexternalhit).*" }
      ],
      "dest": "/who-we-are-og.html",
      "status": 200
    },
    {
      "src": "/autopilot",
      "has": [
        { "type": "header", "key": "user-agent", "value": ".*(bot|crawler|spider|facebookexternalhit).*" }
      ],
      "dest": "/autopilot-og.html",
      "status": 200
    },
    {
      "src": "/compoundiq",
      "has": [
        { "type": "header", "key": "user-agent", "value": ".*(bot|crawler|spider|facebookexternalhit).*" }
      ],
      "dest": "/compoundiq-og.html",
      "status": 200
    },
    { "src": "/api/(.*)", "dest": "/api/index.ts" },
    { "src": "/briefings(/.*)?", "status": 301, "headers": { "Location": "/codex$1" } },
    { "handle": "filesystem" },
    { "src": "/(codex|who-we-are|calendar|pulsenote|brandos|work|purecode|autopilot|compoundiq|events|thesis)(/.*)?", "dest": "/index.html" },
    { "src": "/", "dest": "/index.html" },
    { "src": "/.*", "dest": "/404.html", "status": 404 }
  ]
}
