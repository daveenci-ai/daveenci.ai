{
  "routes": [
    {
      "src": "/calendar",
      "has": [
        { "type": "header", "key": "user-agent", "value": ".*(bot|crawler|spider|facebook|twitter|linkedin|whatsapp|telegram|slack|facebot|twitterbot|slackbot|telegrambot|LinkedInBot).*" }
      ],
      "dest": "/calendar-og.html",
      "status": 200
    },
    {
      "src": "/brand-analyzer",
      "has": [
        { "type": "header", "key": "user-agent", "value": ".*(bot|crawler|spider|facebook|twitter|linkedin|whatsapp|telegram|slack|facebot|twitterbot|slackbot|telegrambot|LinkedInBot).*" }
      ],
      "dest": "/brand-analyzer-og.html",
      "status": 200
    },
    {
      "src": "/book-demo",
      "has": [
        { "type": "header", "key": "user-agent", "value": ".*(bot|crawler|spider|facebook|twitter|linkedin|whatsapp|telegram|slack|facebot|twitterbot|slackbot|telegrambot|LinkedInBot).*" }
      ],
      "dest": "/book-demo-og.html",
      "status": 200
    },
    {
      "src": "/briefings",
      "has": [
        { "type": "header", "key": "user-agent", "value": ".*(bot|crawler|spider|facebook|twitter|linkedin|whatsapp|telegram|slack|facebot|twitterbot|slackbot|telegrambot|LinkedInBot).*" }
      ],
      "dest": "/briefings-og.html",
      "status": 200
    },
    {
      "src": "/who-we-are",
      "has": [
        { "type": "header", "key": "user-agent", "value": ".*(bot|crawler|spider|facebook|twitter|linkedin|whatsapp|telegram|slack|facebot|twitterbot|slackbot|telegrambot|LinkedInBot).*" }
      ],
      "dest": "/who-we-are-og.html",
      "status": 200
    },
    { "src": "/api/(.*)", "dest": "/api/index.ts" },
    { "src": "/briefings(/.*)?", "status": 301, "headers": { "Location": "/codex$1" } },
    { "handle": "filesystem" },
    { "src": "/(codex|who-we-are|calendar|admin|book-demo|brand-analyzer|work|purecode|shootos)(/.*)?", "dest": "/index.html" },
    { "src": "/", "dest": "/index.html" },
    { "src": "/.*", "dest": "/404.html", "status": 404 }
  ]
}
